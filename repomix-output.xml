// ============================================================
// User & Auth
// ============================================================

export interface User {
  user_id: string;
  username?: string;
  role: 'user' | 'admin';
  avatar?: string;
}

export interface LoginRequest {
  user_id: string;
  password: string;
}

export interface LoginResponse {
  token: string;
  user_id: string;
  role: string;
}

export interface UserItem {
  user_id: string;
  role: string;
  is_active: boolean;
  created_at: string;
  updated_at: string;
}

// ============================================================
// Chat & Messages
// ============================================================

export interface Source {
  id: string | number;
  cite_key: string;
  title: string;
