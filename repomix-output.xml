                        await btn.click()
                        await asyncio.sleep(0.5)  # 等待下拉菜单展开
                        
                        # 在下拉菜单中查找PDF链接
                        pdf_link_selectors = self.PDF_SELECTORS['dropdown_pdf_links']
                        
                        for pdf_selector in pdf_link_selectors:
                            try:
