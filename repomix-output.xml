            # ===== 方法5：处理下拉菜单式下载按钮 =====
            # 某些网站（如Frontiersin）需要先点击下拉菜单触发器，再点击PDF链接
            dropdown_triggers = self.PDF_SELECTORS['dropdown_triggers']
            
            for trigger in dropdown_triggers:
                try:
                    btn = page.locator(trigger).first
                    if await btn.is_visible(timeout=1000):
